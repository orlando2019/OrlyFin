# Shared
ENVIRONMENT=local
LOG_LEVEL=INFO
APP_NAME=orlyfin-api

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql+psycopg://orlyfin:orlyfin@localhost:5432/orlyfin

# JWT
JWT_ALGORITHM=HS256
JWT_ACCESS_SECRET_KEY=change-me-access
JWT_REFRESH_SECRET_KEY=change-me-refresh
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
JWT_ACCESS_COOKIE_NAME=of_access_token
JWT_REFRESH_COOKIE_NAME=of_refresh_token
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAMESITE=lax
JWT_COOKIE_DOMAIN=localhost

# Bootstrap security data (local/dev)
BOOTSTRAP_ORG_SLUG=default-org
BOOTSTRAP_ORG_NAME=Default Organization
BOOTSTRAP_ADMIN_EMAIL=admin@orlyfin.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
