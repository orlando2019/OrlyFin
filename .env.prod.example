ENVIRONMENT=prod
LOG_LEVEL=WARNING
APP_NAME=orlyfin-api
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=https://app.orlyfin.app
DATABASE_URL=postgresql+psycopg://orlyfin:${DB_PASSWORD}@db-prod:5432/orlyfin
JWT_ALGORITHM=HS256
JWT_ACCESS_SECRET_KEY=${JWT_ACCESS_SECRET}
JWT_REFRESH_SECRET_KEY=${JWT_REFRESH_SECRET}
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
JWT_ACCESS_COOKIE_NAME=of_access_token
JWT_REFRESH_COOKIE_NAME=of_refresh_token
JWT_COOKIE_SECURE=true
JWT_COOKIE_SAMESITE=strict
JWT_COOKIE_DOMAIN=orlyfin.app
BOOTSTRAP_ORG_SLUG=default-org
BOOTSTRAP_ORG_NAME=Default Organization
BOOTSTRAP_ADMIN_EMAIL=admin@orlyfin.app
BOOTSTRAP_ADMIN_PASSWORD=${BOOTSTRAP_ADMIN_PASSWORD}
NEXT_PUBLIC_API_BASE_URL=https://api.orlyfin.app/api/v1
