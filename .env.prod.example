ENVIRONMENT=prod
LOG_LEVEL=WARNING
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=https://app.orlyfin.app
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
JWT_COOKIE_SECURE=true
JWT_COOKIE_SAMESITE=strict
JWT_COOKIE_DOMAIN=orlyfin.app
DATABASE_URL=postgresql+psycopg://orlyfin:${DB_PASSWORD}@db-prod:5432/orlyfin
NEXT_PUBLIC_API_BASE_URL=https://api.orlyfin.app/api/v1
