ENVIRONMENT=qa
LOG_LEVEL=INFO
APP_NAME=orlyfin-api
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=https://qa.orlyfin.app
DATABASE_URL=postgresql+psycopg://orlyfin:${DB_PASSWORD}@db-qa:5432/orlyfin
JWT_ALGORITHM=HS256
JWT_ACCESS_SECRET_KEY=${JWT_ACCESS_SECRET}
JWT_REFRESH_SECRET_KEY=${JWT_REFRESH_SECRET}
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
JWT_ACCESS_COOKIE_NAME=of_access_token
JWT_REFRESH_COOKIE_NAME=of_refresh_token
JWT_COOKIE_SECURE=true
JWT_COOKIE_SAMESITE=lax
JWT_COOKIE_DOMAIN=qa.orlyfin.app
BOOTSTRAP_ORG_SLUG=default-org
BOOTSTRAP_ORG_NAME=Default Organization
BOOTSTRAP_ADMIN_EMAIL=admin@orlyfin.qa
BOOTSTRAP_ADMIN_PASSWORD=${BOOTSTRAP_ADMIN_PASSWORD}
ATTACHMENTS_STORAGE_PATH=/var/app/storage/attachments
ATTACHMENT_MAX_SIZE_MB=10
ATTACHMENT_ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg,text/csv,text/plain
ALERT_DEBT_DUE_DAYS=7
ALERT_PENDING_EXPENSE_THRESHOLD=10
NEXT_PUBLIC_API_BASE_URL=https://api-qa.orlyfin.app/api/v1
